    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "0fa2b903-8ec8-43bd-bdab-8e15fc7fdce5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def reshape_matrix(a,new_shape):\n",
    "\n",
    "    tot_elements_a=np.size(a)\n",
    "    tot_elements_new_shape=np.prod(new_shape)\n",
    "\n",
    "    if tot_elements_a==tot_elements_new_shape:\n",
    "        return np.reshape(a,new_shape).tolist()\n",
    "    else:\n",
    "        return []"
   ]
